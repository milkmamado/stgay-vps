<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>STGAY — 스윙 트레이딩 분석기</title>
    <script src="https://cdn.jsdelivr.net/npm/lightweight-charts@4.1.0/dist/lightweight-charts.standalone.production.js"></script>
    <style>
        :root {
            --bg-primary: #131722;
            --bg-secondary: #1e222d;
            --bg-tertiary: #2a2e39;
            --bg-card: #1e222d;
            --border: #363a45;
            --text-primary: #d1d4dc;
            --text-secondary: #787b86;
            --text-muted: #5d606b;
            --green: #26a69a;
            --green-light: #4dd0c8;
            --red: #ef5350;
            --blue: #2962ff;
            --yellow: #f7931a;
            --purple: #7b61ff;
            --grade-a: #26a69a;
            --grade-b: #2962ff;
            --grade-c: #f7931a;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: var(--bg-primary); color: var(--text-primary);
            font-family: -apple-system, 'Trebuchet MS', Roboto, Ubuntu, sans-serif;
            font-size: 13px; line-height: 1.5;
        }

        .header {
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border);
            padding: 0 20px; height: 48px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 100;
        }
        .header-left { display: flex; align-items: center; gap: 12px; }
        .logo { font-size: 16px; font-weight: 700; color: #fff; letter-spacing: -0.5px; }
        .logo span { color: var(--green); }
        .header-badge {
            background: var(--bg-tertiary); border: 1px solid var(--border);
            padding: 2px 8px; border-radius: 4px; font-size: 11px; color: var(--text-secondary);
        }
        .header-right { display: flex; align-items: center; gap: 12px; }
        .header-right a { color: var(--text-secondary); font-size: 12px; text-decoration: none; }
        .header-right a:hover { color: var(--text-primary); }

        .container { max-width: 1100px; margin: 0 auto; padding: 16px 20px; }

        .start-btn {
            background: var(--blue); color: #fff; border: none;
            padding: 12px 24px; border-radius: 4px; font-size: 14px;
            font-weight: 600; cursor: pointer; width: 100%; margin-bottom: 16px;
            transition: background 0.15s;
        }
        .start-btn:hover { background: #1e53e5; }
        .start-btn:disabled { opacity: 0.4; cursor: not-allowed; }

        .progress-section { margin-bottom: 16px; }
        .progress-bar { background: var(--bg-tertiary); border-radius: 2px; height: 4px; margin-bottom: 6px; overflow: hidden; }
        .progress-fill { height: 100%; background: var(--blue); transition: width 0.3s; }
        .progress-phase { font-size: 12px; color: var(--text-secondary); margin-bottom: 4px; }

        .summary-bar {
            display: flex; gap: 2px; margin-bottom: 20px;
            background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 4px;
            overflow: hidden;
        }
        .summary-item {
            flex: 1; padding: 14px; text-align: center;
            border-right: 1px solid var(--border);
        }
        .summary-item:last-child { border-right: none; }
        .summary-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
        .summary-value { font-size: 22px; font-weight: 700; margin-top: 2px; }
        .summary-value.green { color: var(--green); }
        .summary-value.blue { color: var(--blue); }
        .summary-value.yellow { color: var(--yellow); }

        /* Theme ranking */
        .theme-ranking {
            background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 4px;
            padding: 16px; margin-bottom: 20px;
        }
        .theme-ranking-title {
            font-size: 12px; font-weight: 600; color: var(--text-secondary);
            text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px;
        }
        .theme-chips { display: flex; flex-wrap: wrap; gap: 6px; }
        .theme-chip {
            display: inline-flex; align-items: center; gap: 6px;
            background: var(--bg-tertiary); border: 1px solid var(--border);
            padding: 5px 10px; border-radius: 4px; font-size: 12px;
            color: var(--text-primary); transition: border-color 0.15s;
        }
        .theme-chip:hover { border-color: var(--blue); }
        .theme-rank { color: var(--yellow); font-weight: 800; font-size: 11px; min-width: 18px; }
        .theme-name { font-weight: 500; }
        .theme-count { color: var(--text-muted); font-size: 11px; }

        /* AI Market View */
        .ai-market-view {
            background: var(--bg-secondary); border: 1px solid var(--border);
            border-left: 3px solid var(--purple); border-radius: 4px;
            padding: 14px 16px; margin-bottom: 20px;
        }
        .ai-market-title { color: var(--purple); font-size: 12px; font-weight: 700; margin-bottom: 8px; }
        .ai-market-text { font-size: 13px; color: var(--text-primary); line-height: 1.6; }
        .ai-strategy { margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--border); color: var(--text-secondary); font-size: 12px; }


        /* AI TOP 3 Section */
        .top3-section {
            margin-bottom: 24px;
        }
        .top3-header {
            display: flex; align-items: center; gap: 10px;
            margin-bottom: 16px; padding-bottom: 12px;
            border-bottom: 2px solid var(--yellow);
        }
        .top3-title {
            font-size: 18px; font-weight: 800; color: #fff;
            display: flex; align-items: center; gap: 8px;
        }
        .top3-title .crown { font-size: 22px; }
        .top3-subtitle { font-size: 12px; color: var(--text-secondary); }

        .top3-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 6px; margin-bottom: 14px;
            overflow: hidden; position: relative;
        }
        .top3-card.rank-1 { border-left: 4px solid #ffd700; }
        .top3-card.rank-2 { border-left: 4px solid #c0c0c0; }
        .top3-card.rank-3 { border-left: 4px solid #cd7f32; }

        .top3-card-header {
            padding: 16px 18px; display: flex; justify-content: space-between;
            align-items: center; border-bottom: 1px solid var(--border);
        }
        .top3-rank-badge {
            width: 36px; height: 36px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-weight: 900; font-size: 16px; color: #000;
        }
        .top3-rank-badge.r1 { background: linear-gradient(135deg, #ffd700, #ffaa00); }
        .top3-rank-badge.r2 { background: linear-gradient(135deg, #e0e0e0, #a0a0a0); }
        .top3-rank-badge.r3 { background: linear-gradient(135deg, #cd7f32, #a0622e); }

        .top3-stock-info { display: flex; align-items: center; gap: 12px; }
        .top3-stock-name { font-size: 18px; font-weight: 700; color: #fff; }
        .top3-stock-code { font-size: 12px; color: var(--text-muted); }
        .top3-stock-theme { background: rgba(123,97,255,0.15); color: var(--purple); padding: 2px 8px; border-radius: 3px; font-size: 11px; }

        .top3-confidence {
            display: flex; align-items: center; gap: 6px;
        }
        .confidence-bar {
            width: 60px; height: 6px; background: var(--bg-tertiary);
            border-radius: 3px; overflow: hidden;
        }
        .confidence-fill { height: 100%; border-radius: 3px; }
        .confidence-text { font-size: 13px; font-weight: 700; }

        .top3-summary {
            padding: 14px 18px; border-bottom: 1px solid var(--border);
            font-size: 14px; color: var(--text-primary); line-height: 1.7;
            background: rgba(247,147,26,0.03);
        }

        .top3-reasons {
            padding: 14px 18px; border-bottom: 1px solid var(--border);
        }
        .top3-reasons-title { font-size: 11px; color: var(--yellow); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
        .top3-reason {
            padding: 6px 0; font-size: 13px; color: var(--text-primary);
            line-height: 1.6; border-bottom: 1px solid rgba(54,58,69,0.5);
        }
        .top3-reason:last-child { border-bottom: none; }
        .top3-reason-num { color: var(--yellow); font-weight: 700; margin-right: 6px; }

        .top3-entry-plan {
            padding: 14px 18px; border-bottom: 1px solid var(--border);
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
        }
        .top3-plan-item {}
        .top3-plan-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; margin-bottom: 2px; }
        .top3-plan-value { font-size: 14px; font-weight: 600; }
        .top3-plan-value.entry { color: var(--blue); }
        .top3-plan-value.target { color: var(--green); }
        .top3-plan-value.stop { color: var(--red); }
        .top3-plan-value.neutral { color: var(--text-primary); }

        .top3-risks {
            padding: 14px 18px; border-bottom: 1px solid var(--border);
        }
        .top3-risk-item {
            display: flex; align-items: flex-start; gap: 8px;
            padding: 6px 0; font-size: 12px;
        }
        .top3-risk-severity {
            padding: 1px 6px; border-radius: 3px; font-size: 10px; font-weight: 600;
            flex-shrink: 0;
        }
        .top3-risk-severity.high { background: rgba(239,83,80,0.15); color: var(--red); }
        .top3-risk-severity.medium { background: rgba(247,147,26,0.15); color: var(--yellow); }
        .top3-risk-severity.low { background: rgba(38,166,154,0.15); color: var(--green); }
        .top3-risk-detail { color: var(--text-secondary); line-height: 1.5; }
        .top3-risk-mitigation { color: var(--text-muted); font-size: 11px; margin-top: 2px; }

        .top3-catalysts {
            padding: 12px 18px; border-bottom: 1px solid var(--border);
        }
        .top3-catalyst-tag {
            display: inline-block; background: rgba(41,98,255,0.1); color: #5b9cf6;
            padding: 3px 8px; border-radius: 3px; font-size: 11px; margin: 2px 4px 2px 0;
        }

        .top3-news-momentum {
            padding: 12px 18px; font-size: 12px; color: var(--text-secondary); line-height: 1.6;
        }

        .ai-context-box {
            background: var(--bg-secondary); border: 1px solid var(--border);
            border-left: 3px solid var(--purple); border-radius: 4px;
            padding: 14px 18px; margin-bottom: 20px;
        }
        .ai-context-title { color: var(--purple); font-size: 12px; font-weight: 700; margin-bottom: 6px; }
        .ai-context-text { font-size: 13px; color: var(--text-primary); line-height: 1.7; }
        .ai-caution { margin-top: 10px; padding-top: 8px; border-top: 1px solid var(--border); color: var(--red); font-size: 12px; }

        .section-divider {
            height: 1px; background: var(--border); margin: 24px 0;
        }

        /* Stock Card */
        .stock-card {
            background: var(--bg-card); border: 1px solid var(--border); border-radius: 4px;
            margin-bottom: 16px; overflow: hidden;
        }
        .card-top {
            padding: 14px 16px; display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid var(--border);
        }
        .card-top-left { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
        .stock-name { font-size: 16px; font-weight: 700; color: #fff; }
        .stock-code { color: var(--text-muted); font-size: 12px; }
        .stock-theme {
            background: rgba(123,97,255,0.15); color: var(--purple);
            padding: 2px 8px; border-radius: 3px; font-size: 11px; font-weight: 500;
        }
        .grade-badge { display: flex; align-items: center; gap: 8px; }
        .grade-chip {
            padding: 4px 14px; border-radius: 3px; font-weight: 700; font-size: 14px; color: #fff;
        }
        .grade-chip.A { background: var(--grade-a); }
        .grade-chip.B { background: var(--grade-b); }
        .grade-chip.C { background: var(--grade-c); }
        .grade-label { font-size: 12px; }
        .grade-score { font-size: 11px; color: var(--text-muted); }

        .card-price {
            padding: 10px 16px; display: flex; align-items: baseline; gap: 8px;
            border-bottom: 1px solid var(--border);
        }
        .price-current { font-size: 24px; font-weight: 700; color: #fff; }
        .price-won { font-size: 13px; color: var(--text-secondary); }

        /* Chart — tall */
        .chart-container {
            height: 380px; padding: 0; border-bottom: 1px solid var(--border);
            position: relative;
        }

        /* Stages */
        .stages-bar {
            display: flex; padding: 0; border-bottom: 1px solid var(--border);
        }
        .stage-item {
            flex: 1; padding: 10px 12px; text-align: center;
            border-right: 1px solid var(--border); font-size: 11px;
        }
        .stage-item:last-child { border-right: none; }
        .stage-item.passed { background: rgba(38,166,154,0.08); }
        .stage-item.failed { background: rgba(239,83,80,0.05); }
        .stage-label { color: var(--text-muted); font-size: 10px; margin-bottom: 2px; }
        .stage-status { font-weight: 600; }
        .stage-status.pass { color: var(--green); }
        .stage-status.fail { color: var(--text-muted); }

        /* Signals */
        .signals-section { padding: 12px 16px; border-bottom: 1px solid var(--border); }
        .signal-group-title { font-size: 11px; color: var(--text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
        .signal-list { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px; }
        .signal-tag { padding: 3px 8px; border-radius: 3px; font-size: 11px; line-height: 1.4; }
        .signal-tag.positive { background: rgba(38,166,154,0.12); color: var(--green-light); }
        .signal-tag.warning { background: rgba(247,147,26,0.12); color: var(--yellow); }
        .signal-tag.ref { background: rgba(41,98,255,0.1); color: #5b9cf6; }
        .signal-tag.risk { background: rgba(239,83,80,0.12); color: var(--red); }

        /* Supply demand */
        .supply-row {
            display: flex; gap: 16px; padding: 10px 16px; border-bottom: 1px solid var(--border);
            font-size: 12px;
        }
        .supply-item { display: flex; align-items: center; gap: 4px; }
        .supply-label { color: var(--text-muted); }
        .supply-value.positive { color: var(--green); font-weight: 600; }
        .supply-value.negative { color: var(--red); font-weight: 600; }

        /* AI per-stock */
        .ai-stock-section {
            padding: 12px 16px; border-bottom: 1px solid var(--border);
            background: rgba(123,97,255,0.03);
        }
        .ai-verdict { font-size: 13px; font-weight: 600; margin-bottom: 6px; }
        .ai-verdict.buy { color: var(--green); }
        .ai-verdict.hold { color: var(--yellow); }
        .ai-verdict.avoid { color: var(--red); }
        .ai-detail { font-size: 12px; color: var(--text-secondary); line-height: 1.6; }
        .ai-risks { margin-top: 6px; }
        .ai-risk-tag {
            display: inline-block; padding: 2px 6px; border-radius: 3px;
            font-size: 11px; margin-right: 4px; margin-bottom: 2px;
        }
        .ai-risk-tag.low { background: rgba(38,166,154,0.1); color: var(--green); }
        .ai-risk-tag.medium { background: rgba(247,147,26,0.1); color: var(--yellow); }
        .ai-risk-tag.high { background: rgba(239,83,80,0.12); color: var(--red); }

        /* Trade guide */
        .trade-guide {
            padding: 14px 16px;
            background: linear-gradient(135deg, rgba(38,166,154,0.04), rgba(41,98,255,0.04));
        }
        .trade-title { font-size: 11px; color: var(--text-muted); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
        .trade-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
        .trade-label { font-size: 10px; color: var(--text-muted); }
        .trade-value { font-size: 14px; font-weight: 700; margin-top: 1px; }
        .trade-pct { font-size: 11px; color: var(--text-secondary); }
        .trade-value.entry { color: var(--text-primary); }
        .trade-value.target { color: var(--green); }
        .trade-value.stop { color: var(--red); }
        .trade-meta {
            display: flex; gap: 20px; margin-top: 10px; padding-top: 8px;
            border-top: 1px solid var(--border);
        }
        .trade-meta-item { font-size: 12px; }
        .trade-meta-item span { color: var(--text-muted); }

        .empty-state { text-align: center; padding: 60px 20px; }
        .empty-icon { font-size: 40px; margin-bottom: 12px; }
        .empty-text { color: var(--text-muted); font-size: 14px; }

        .section-title {
            font-size: 13px; font-weight: 600; color: var(--text-secondary);
            margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-left">
            <div class="logo">ST<span>GAY</span></div>
            <span class="header-badge">Swing v4</span>
            <span id="statusBadge" class="header-badge" style="display:none;"></span>
        </div>
        <div class="header-right">
            <a href="/stgay/logout">로그아웃</a>
        </div>
    </div>

    <div class="container">
        <button class="start-btn" id="startBtn" onclick="startAnalysis()">
            🔍 스윙 분석 시작
        </button>

        <div class="progress-section" id="progressSection" style="display:none;">
            <div class="progress-phase" id="progressPhase"></div>
            <div class="progress-bar"><div class="progress-fill" id="progressFill" style="width:0%"></div></div>
        </div>

        <div id="resultArea"></div>
    </div>

<script>
const escHtml = s => s ? s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') : '';
let pollTimer = null;
let chartInstances = {};

function startAnalysis() {
    const btn = document.getElementById('startBtn');
    btn.disabled = true;
    btn.textContent = '분석 진행 중...';
    document.getElementById('progressSection').style.display = 'block';
    document.getElementById('resultArea').innerHTML = '';

    fetch('/stgay/api/start', { method: 'POST' })
        .then(r => r.json())
        .then(() => { pollTimer = setInterval(pollStatus, 1500); })
        .catch(e => { btn.disabled = false; btn.textContent = '🔍 스윙 분석 시작'; alert('시작 실패: ' + e); });
}

function pollStatus() {
    fetch('/stgay/api/status').then(r => r.json()).then(data => {
        document.getElementById('progressPhase').textContent = data.phase || '';
        document.getElementById('progressFill').style.width = (data.percent || 0) + '%';

        const badge = document.getElementById('statusBadge');
        if (data.running) {
            badge.style.display = 'inline'; badge.textContent = data.phase;
        }

        if (!data.running) {
            clearInterval(pollTimer);
            badge.style.display = 'none';
            document.getElementById('startBtn').disabled = false;
            document.getElementById('startBtn').textContent = '🔍 스윙 분석 시작';

            if (data.has_result) {
                fetch('/stgay/api/result').then(r => r.json()).then(renderDashboard);
            } else if (data.error) {
                document.getElementById('resultArea').innerHTML =
                    `<div style="color:var(--red);padding:20px;">❌ 오류: ${escHtml(data.error)}</div>`;
            }
            document.getElementById('progressSection').style.display = 'none';
        }
    });
}

function renderDashboard(data) {
    const el = document.getElementById('resultArea');
    const s = data.stocks_summary || {};
    const ai = data.ai_analysis || {};
    const aiReport = ai.final_report || {};
    const themes = data.themes || [];
    const allStocks = Object.values(data.tech_analysis || {});
    const showStocks = allStocks.filter(s => s.show || s.show_c)
        .sort((a, b) => (a.theme_rank || 99) - (b.theme_rank || 99) || (b.swing?.score || 0) - (a.swing?.score || 0));

    // Build theme rank lookup: theme name → rank number
    const themeRankMap = {};
    themes.forEach((t, i) => { themeRankMap[t.name] = i + 1; });

    // Build AI stock lookup
    const aiStockMap = {};
    if (aiReport.stocks) {
        aiReport.stocks.forEach(s => { aiStockMap[s.name] = s; });
    }

    let html = '';

    // Summary bar
    html += `<div class="summary-bar">
        <div class="summary-item">
            <div class="summary-label">분석</div>
            <div class="summary-value">${s.total_scanned || 0}</div>
        </div>
        <div class="summary-item">
            <div class="summary-label">A등급</div>
            <div class="summary-value green">${s.grade_a || 0}</div>
        </div>
        <div class="summary-item">
            <div class="summary-label">B등급</div>
            <div class="summary-value blue">${s.grade_b || 0}</div>
        </div>
        <div class="summary-item">
            <div class="summary-label">C 관심</div>
            <div class="summary-value yellow">${s.grade_c || 0}</div>
        </div>
        <div class="summary-item">
            <div class="summary-label">뉴스</div>
            <div class="summary-value">${data.total_articles || 0}</div>
        </div>
    </div>`;

    // Theme ranking
    if (themes.length) {
        html += `<div class="theme-ranking">
            <div class="theme-ranking-title">🏷️ 오늘의 테마 랭킹</div>
            <div class="theme-chips">`;
        themes.slice(0, 15).forEach((t, i) => {
            html += `<div class="theme-chip">
                <span class="theme-rank">#${i+1}</span>
                <span class="theme-name">${escHtml(t.name)}</span>
                <span class="theme-count">${t.count}건</span>
            </div>`;
        });
        html += '</div></div>';
    }

    // AI TOP 3 추천
    const aiTop3 = ai.top3 || {};
    const top3List = aiTop3.top3 || [];
    const aiErrors = [ai.news_flow?.error, ai.final_report?.error, aiTop3?.error].filter(Boolean);
    const aiRawHints = [ai.news_flow?.raw_text, ai.final_report?.raw_text, aiTop3?.raw_text].filter(Boolean);

    if (top3List.length > 0) {
        html += '<div class="top3-section">';
        html += `<div class="top3-header">
            <div class="top3-title"><span class="crown">👑</span> AI 최종 추천 TOP ${top3List.length}</div>
            <div class="top3-subtitle">Claude AI가 기술적 분석 + 뉴스 + 수급을 종합하여 선정</div>
        </div>`;

        top3List.forEach((item, idx) => {
            const rank = item.rank || (idx + 1);
            const plan = item.entry_plan || {};
            const confPct = item.confidence || 0;
            const confColor = confPct >= 80 ? 'var(--green)' : confPct >= 60 ? 'var(--yellow)' : 'var(--red)';

            html += `<div class="top3-card rank-${rank}">
                <div class="top3-card-header">
                    <div class="top3-stock-info">
                        <div class="top3-rank-badge r${rank}">${rank}</div>
                        <div>
                            <span class="top3-stock-name">${escHtml(item.name || '')}</span>
                            <span class="top3-stock-code">${item.code || ''}</span>
                        </div>
                        ${item.theme ? `<span class="top3-stock-theme">${escHtml(item.theme)}</span>` : ''}
                    </div>
                    <div class="top3-confidence">
                        <div class="confidence-bar"><div class="confidence-fill" style="width:${confPct}%;background:${confColor}"></div></div>
                        <span class="confidence-text" style="color:${confColor}">${confPct}%</span>
                    </div>
                </div>

                <div class="top3-summary">${escHtml(item.summary || '')}</div>

                ${(item.reasons && item.reasons.length) ? `<div class="top3-reasons">
                    <div class="top3-reasons-title">📋 선정 근거</div>
                    ${item.reasons.map((r, ri) => `<div class="top3-reason"><span class="top3-reason-num">${ri+1}.</span>${escHtml(r)}</div>`).join('')}
                </div>` : ''}

                <div class="top3-entry-plan">
                    <div class="top3-plan-item"><div class="top3-plan-label">진입가</div><div class="top3-plan-value entry">${escHtml(plan.entry_price || '-')}</div></div>
                    <div class="top3-plan-item"><div class="top3-plan-label">목표가</div><div class="top3-plan-value target">${escHtml(plan.target_price || '-')}</div></div>
                    <div class="top3-plan-item"><div class="top3-plan-label">손절가</div><div class="top3-plan-value stop">${escHtml(plan.stop_loss || '-')}</div></div>
                    <div class="top3-plan-item"><div class="top3-plan-label">예상 수익</div><div class="top3-plan-value neutral">${escHtml(plan.expected_return || '-')}</div></div>
                    <div class="top3-plan-item"><div class="top3-plan-label">손익비</div><div class="top3-plan-value neutral">${escHtml(plan.risk_reward || '-')}</div></div>
                    <div class="top3-plan-item"><div class="top3-plan-label">보유 기간</div><div class="top3-plan-value neutral">${escHtml(plan.holding_period || '-')}</div></div>
                </div>

                ${(item.risks && item.risks.length) ? `<div class="top3-risks">
                    <div class="top3-reasons-title">⚠️ 리스크 분석</div>
                    ${item.risks.map(r => `<div class="top3-risk-item">
                        <span class="top3-risk-severity ${r.severity || 'medium'}">${(r.severity || 'medium').toUpperCase()}</span>
                        <div>
                            <div class="top3-risk-detail">${escHtml(r.factor || '')}</div>
                            ${r.mitigation ? `<div class="top3-risk-mitigation">→ ${escHtml(r.mitigation)}</div>` : ''}
                        </div>
                    </div>`).join('')}
                </div>` : ''}

                ${(item.catalysts && item.catalysts.length) ? `<div class="top3-catalysts">
                    <div class="top3-reasons-title">🚀 향후 촉매제</div>
                    ${item.catalysts.map(c => `<span class="top3-catalyst-tag">${escHtml(c)}</span>`).join('')}
                </div>` : ''}

                ${item.news_momentum ? `<div class="top3-news-momentum">
                    <strong>📰 뉴스 모멘텀:</strong> ${escHtml(item.news_momentum)}
                </div>` : ''}
            </div>`;
        });

        html += '</div>';
    }

    // AI 시장 판단 + 전략
    const marketView = aiTop3.market_context || aiReport.market_view || '';
    const strategyNote = aiTop3.strategy_note || aiReport.overall_strategy || '';
    const caution = aiTop3.caution || '';
    const newsFlow = ai.news_flow || {};

    if (marketView || strategyNote || newsFlow.summary || aiErrors.length || aiRawHints.length || !top3List.length) {
        html += `<div class="ai-context-box">
            <div class="ai-context-title">🧠 AI 시장 판단</div>
            ${marketView ? `<div class="ai-context-text">${escHtml(marketView)}</div>` : ''}
            ${strategyNote ? `<div class="ai-context-text" style="margin-top:8px"><strong>📋 전략:</strong> ${escHtml(strategyNote)}</div>` : ''}
            ${newsFlow.summary ? `<div class="ai-context-text" style="margin-top:8px"><strong>📰 뉴스플로우:</strong> ${escHtml(newsFlow.summary)}</div>` : ''}
            ${!top3List.length ? `<div class="ai-context-text" style="margin-top:8px"><strong>👑 TOP3:</strong> 아직 생성되지 않았습니다.</div>` : ''}
            ${aiErrors.length ? `<div class="ai-caution">⚠️ AI 오류: ${escHtml(aiErrors.join(' | '))}</div>` : ''}
            ${!aiErrors.length && aiRawHints.length ? `<div class="ai-context-text" style="margin-top:8px"><strong>ℹ️ AI 응답:</strong> ${escHtml(String(aiRawHints[0]).slice(0, 300))}</div>` : ''}
            ${caution ? `<div class="ai-caution">⚠️ ${escHtml(caution)}</div>` : ''}
        </div>`;
    }

    // Stocks
    if (!showStocks.length) {
        html += `<div class="empty-state">
            <div class="empty-icon">📊</div>
            <div class="empty-text">오늘은 스윙 조건에 부합하는 종목이 없습니다</div>
        </div>`;
    } else {
        html += '<div class="section-title">📈 스윙 추천 종목</div>';
        showStocks.forEach(stock => {
            const aiInfo = aiStockMap[stock.name] || null;
            html += renderStockCard(stock, aiInfo, themeRankMap);
        });
    }

    el.innerHTML = html;

    // Render charts after DOM
    setTimeout(() => {
        showStocks.forEach(stock => renderChart(stock));
    }, 150);
}

function renderStockCard(stock, aiInfo, themeRankMap) {
    const sw = stock.swing || {};
    const grade = sw.grade || 'D';
    const tg = sw.trading_guide || {};
    const signals = sw.signals || [];
    const warnings = sw.warnings || [];
    const refSignals = sw.ref_signals || [];
    const stage1 = sw.stage1 || {};
    const stage2 = sw.stage2 || {};
    const stage3 = sw.stage3 || {};
    const sd = (stage3.supply_demand || {});
    const sdData = sd.data || {};

    const chartId = 'chart-' + stock.code;
    const themeName = stock.theme || '';
    const themeRank = themeRankMap[themeName];
    const themeDisplay = themeName ? (themeRank ? `${themeName}-${themeRank}위` : themeName) : '';

    let html = `<div class="stock-card">
        <div class="card-top">
            <div class="card-top-left">
                <span class="stock-name">${escHtml(stock.name)}</span>
                <span class="stock-code">${stock.code}</span>
                <span class="stock-theme">${escHtml(themeDisplay)}</span>
            </div>
            <div class="grade-badge">
                <span class="grade-chip ${grade}">${grade}</span>
                <span class="grade-label" style="color:${sw.color || '#666'}">${sw.label || ''}</span>
                <span class="grade-score">${sw.score || 0}점 · ${sw.stages_passed || 0}/3</span>
            </div>
        </div>

        <div class="card-price">
            <span class="price-current">${(stock.current_price || 0).toLocaleString()}</span>
            <span class="price-won">원</span>
            ${stock.market_cap ? `<span style="color:var(--text-muted);font-size:12px;margin-left:auto;">시총 ${stock.market_cap.toLocaleString()}억</span>` : ''}
        </div>

        <div class="chart-container" id="${chartId}"></div>

        <div class="stages-bar">
            <div class="stage-item ${stage1.passed ? 'passed' : 'failed'}">
                <div class="stage-label">1차 장대양봉</div>
                <div class="stage-status ${stage1.passed ? 'pass' : 'fail'}">${stage1.passed ? '✓ ' + (stage1.count || 0) + '회' : '✗ 미감지'}</div>
            </div>
            <div class="stage-item ${stage2.passed ? 'passed' : 'failed'}">
                <div class="stage-label">2차 박스권</div>
                <div class="stage-status ${stage2.passed ? 'pass' : 'fail'}">${stage2.passed ? '✓ 형성' : '✗ 미형성'}</div>
            </div>
            <div class="stage-item ${stage3.passed ? 'passed' : 'failed'}">
                <div class="stage-label">3차 수급</div>
                <div class="stage-status ${stage3.passed ? 'pass' : 'fail'}">${stage3.passed ? '✓ 유입' : '✗ 미확인'}</div>
            </div>
        </div>`;

    // Signals
    if (signals.length || warnings.length || refSignals.length) {
        html += '<div class="signals-section">';
        if (signals.length) {
            html += '<div class="signal-group-title">매수 시그널</div><div class="signal-list">';
            signals.forEach(s => { html += `<span class="signal-tag positive">${escHtml(s)}</span>`; });
            html += '</div>';
        }
        if (refSignals.length) {
            html += '<div class="signal-group-title">참고 지표</div><div class="signal-list">';
            refSignals.forEach(s => { html += `<span class="signal-tag ref">${escHtml(s)}</span>`; });
            html += '</div>';
        }
        if (warnings.length) {
            html += '<div class="signal-group-title">주의사항 / 악재</div><div class="signal-list">';
            warnings.forEach(s => {
                const isRisk = s.includes('악재') || s.includes('⚠️');
                html += `<span class="signal-tag ${isRisk ? 'risk' : 'warning'}">${escHtml(s)}</span>`;
            });
            html += '</div>';
        }
        html += '</div>';
    }

    // Supply demand row
    if (sdData.daily) {
        html += `<div class="supply-row">
            <div class="supply-item"><span class="supply-label">외국인 5일</span>
                <span class="supply-value ${sdData.foreign_5d >= 0 ? 'positive' : 'negative'}">${(sdData.foreign_5d || 0).toLocaleString()}주</span></div>
            <div class="supply-item"><span class="supply-label">기관 5일</span>
                <span class="supply-value ${sdData.institution_5d >= 0 ? 'positive' : 'negative'}">${(sdData.institution_5d || 0).toLocaleString()}주</span></div>
            <div class="supply-item"><span class="supply-label">외국인 연속</span>
                <span class="supply-value ${sdData.foreign_consec >= 3 ? 'positive' : ''}">${sdData.foreign_consec || 0}일</span></div>
            <div class="supply-item"><span class="supply-label">기관 연속</span>
                <span class="supply-value ${sdData.institution_consec >= 3 ? 'positive' : ''}">${sdData.institution_consec || 0}일</span></div>
        </div>`;
    }

    // AI analysis per stock
    if (aiInfo) {
        const verdictClass = (aiInfo.verdict === '적극매수' || aiInfo.verdict === '매수고려') ? 'buy'
            : (aiInfo.verdict === '보류') ? 'hold' : 'avoid';
        html += `<div class="ai-stock-section">
            <div class="ai-verdict ${verdictClass}">🧠 AI: ${escHtml(aiInfo.verdict)} (신뢰도 ${aiInfo.confidence || '-'}%)</div>`;
        if (aiInfo.key_signal) {
            html += `<div class="ai-detail">💡 ${escHtml(aiInfo.key_signal)}</div>`;
        }
        if (aiInfo.entry_scenario) {
            html += `<div class="ai-detail" style="margin-top:4px;">📍 ${escHtml(aiInfo.entry_scenario)}</div>`;
        }
        if (aiInfo.risks && aiInfo.risks.length) {
            html += '<div class="ai-risks">';
            aiInfo.risks.forEach(r => {
                html += `<span class="ai-risk-tag ${r.severity || 'medium'}">${escHtml(r.type)}: ${escHtml(r.detail)}</span>`;
            });
            html += '</div>';
        }
        if (aiInfo.risk_note) {
            html += `<div class="ai-detail" style="margin-top:4px;color:var(--yellow);">⚠️ ${escHtml(aiInfo.risk_note)}</div>`;
        }
        html += '</div>';
    }

    // Trade guide
    if (tg.entry_low) {
        html += `<div class="trade-guide">
            <div class="trade-title">매매 가이드 (1~2주 스윙)</div>
            <div class="trade-grid">
                <div>
                    <div class="trade-label">진입가</div>
                    <div class="trade-value entry">${tg.entry_low?.toLocaleString()} ~ ${tg.entry_high?.toLocaleString()}</div>
                </div>
                <div>
                    <div class="trade-label">1차 익절</div>
                    <div class="trade-value target">${tg.target1?.toLocaleString()}</div>
                    <div class="trade-pct">${tg.target1_pct > 0 ? '+' : ''}${tg.target1_pct}%</div>
                </div>
                <div>
                    <div class="trade-label">2차 익절</div>
                    <div class="trade-value target">${tg.target2?.toLocaleString()}</div>
                    <div class="trade-pct">${tg.target2_pct > 0 ? '+' : ''}${tg.target2_pct}%</div>
                </div>
                <div>
                    <div class="trade-label">손절</div>
                    <div class="trade-value stop">${tg.stop_loss?.toLocaleString()}</div>
                    <div class="trade-pct">${tg.stop_pct}%</div>
                </div>
            </div>
            <div class="trade-meta">
                <div class="trade-meta-item"><span>추세 </span>${tg.trend || ''}</div>
                <div class="trade-meta-item"><span>손익비 </span><b>${tg.risk_reward || 0}:1</b></div>
                <div class="trade-meta-item"><span>ATR </span>${tg.atr?.toLocaleString() || '-'}</div>
            </div>
        </div>`;
    }

    html += '</div>';
    return html;
}

function fmtDate(d) {
    if (!d) return d;
    if (d.length === 8) return d.slice(0,4) + '-' + d.slice(4,6) + '-' + d.slice(6,8);
    return d;
}

function renderChart(stock) {
    const containerId = 'chart-' + stock.code;
    const container = document.getElementById(containerId);
    if (!container || !stock.prices || !stock.prices.length) return;

    container.innerHTML = '';

    if (chartInstances[stock.code]) {
        try { chartInstances[stock.code].remove(); } catch(e) {}
    }

    const chart = LightweightCharts.createChart(container, {
        width: container.clientWidth,
        height: 380,
        layout: { background: { color: '#131722' }, textColor: '#787b86', fontSize: 11 },
        grid: { vertLines: { color: '#1e222d' }, horzLines: { color: '#1e222d' } },
        crosshair: { mode: LightweightCharts.CrosshairMode.Normal },
        rightPriceScale: { borderColor: '#363a45' },
        timeScale: { borderColor: '#363a45', timeVisible: false, rightOffset: 3 },
    });

    chartInstances[stock.code] = chart;

    const candleSeries = chart.addCandlestickSeries({
        upColor: '#26a69a', downColor: '#ef5350',
        borderUpColor: '#26a69a', borderDownColor: '#ef5350',
        wickUpColor: '#26a69a', wickDownColor: '#ef5350',
    });

    const candleData = stock.prices.map(p => ({
        time: fmtDate(p.date), open: p.open, high: p.high, low: p.low, close: p.close,
    }));
    candleSeries.setData(candleData);

    // Volume
    const volSeries = chart.addHistogramSeries({
        priceFormat: { type: 'volume' },
        priceScaleId: 'vol',
    });
    chart.priceScale('vol').applyOptions({
        scaleMargins: { top: 0.85, bottom: 0 },
    });
    volSeries.setData(stock.prices.map(p => ({
        time: fmtDate(p.date), value: p.volume,
        color: p.close >= p.open ? 'rgba(38,166,154,0.3)' : 'rgba(239,83,80,0.3)',
    })));

    // Mark 장대양봉 only (lightweight marker)
    const sw = stock.swing || {};
    const stage1 = sw.stage1 || {};
    if (stage1.candles && stage1.candles.length) {
        const markers = stage1.candles.map(bc => ({
            time: fmtDate(bc.date),
            position: 'aboveBar',
            color: bc.strength === 'strong' ? '#f7931a' : '#26a69a',
            shape: 'arrowDown',
            text: `Vol ${bc.vol_ratio}x`,
        }));
        candleSeries.setMarkers(markers);
    }

    chart.timeScale().fitContent();

    // Responsive
    const ro = new ResizeObserver(() => {
        chart.applyOptions({ width: container.clientWidth });
    });
    ro.observe(container);
}
</script>
</body>
</html>
